# Server
PORT=8000

# Comma-separated frontend origins allowed by CORS (required when API and React are on different hosts)
CORS_ORIGIN=http://localhost:3000

# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/subtitlesearcher

# JWT (use a long random string in production)
JWT_SECRET=SomeLongKeyForJWTSigning1234567890

# OpenSubtitles — https://www.opensubtitles.com/en/consumers
OS_API_KEY=your_api_key_here
OS_USERNAME=your_username_here
OS_PASSWORD=your_password_here
OS_USER_AGENT=MySubtitleBackend v1.0